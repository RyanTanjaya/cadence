# --- Dev (SQLite) ---
DATABASE_URL="file:./dev.db"

# --- Prod (Supabase Postgres) — switch schema.prisma provider to "postgresql" ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001
CORS_ORIGIN="http://localhost:5173"

# Optional — enables the Journal "Get a reflection" feature (Anthropic API).
# Without it, the reflect endpoint returns a friendly "not configured" message.
# ANTHROPIC_API_KEY="sk-ant-..."
